<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoair.uav.mapper.SysUavResultMapper">
    
    <resultMap type="SysUavResult" id="SysUavResultResult">
        <result property="resultId"    column="result_id"    />
        <result property="resultCode"    column="result_code"    />
        <result property="taskId"    column="task_id"    />
        <result property="overview"    column="overview"    />
        <result property="findings"    column="findings"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectSysUavResultVo">
        select result_id, result_code, task_id, overview, findings, create_by, create_time, update_by, update_time, remark from sys_uav_result
    </sql>

    <select id="selectSysUavResultList" parameterType="SysUavResult" resultMap="SysUavResultResult">
        <include refid="selectSysUavResultVo"/>
        <where>  
            <if test="resultCode != null  and resultCode != ''"> and result_code = #{resultCode}</if>
            <if test="taskId != null "> and task_id = #{taskId}</if>
        </where>
    </select>
    
    <select id="selectSysUavResultByResultId" parameterType="Long" resultMap="SysUavResultResult">
        <include refid="selectSysUavResultVo"/>
        where result_id = #{resultId}
    </select>

    <insert id="insertSysUavResult" parameterType="SysUavResult" useGeneratedKeys="true" keyProperty="resultId">
        insert into sys_uav_result
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="resultCode != null and resultCode != ''">result_code,</if>
            <if test="taskId != null">task_id,</if>
            <if test="overview != null and overview != ''">overview,</if>
            <if test="findings != null">findings,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="resultCode != null and resultCode != ''">#{resultCode},</if>
            <if test="taskId != null">#{taskId},</if>
            <if test="overview != null and overview != ''">#{overview},</if>
            <if test="findings != null">#{findings},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updateSysUavResult" parameterType="SysUavResult">
        update sys_uav_result
        <trim prefix="SET" suffixOverrides=",">
            <if test="resultCode != null and resultCode != ''">result_code = #{resultCode},</if>
            <if test="taskId != null">task_id = #{taskId},</if>
            <if test="overview != null and overview != ''">overview = #{overview},</if>
            <if test="findings != null">findings = #{findings},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where result_id = #{resultId}
    </update>

    <delete id="deleteSysUavResultByResultId" parameterType="Long">
        delete from sys_uav_result where result_id = #{resultId}
    </delete>

    <delete id="deleteSysUavResultByResultIds" parameterType="String">
        delete from sys_uav_result where result_id in 
        <foreach item="resultId" collection="array" open="(" separator="," close=")">
            #{resultId}
        </foreach>
    </delete>
</mapper>