<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoair.uav.mapper.SysUavDashboardMapper">

    <select id="countEquipment" resultType="int">
        SELECT count(1) FROM sys_uav_equipment
    </select>

    <select id="countRoute" resultType="int">
        SELECT count(1) FROM sys_uav_route
    </select>

    <select id="countTask" resultType="int">
        SELECT count(1) FROM sys_uav_task
    </select>

    <select id="countResult" resultType="int">
        SELECT count(1) FROM sys_uav_result
    </select>

    <select id="selectEquipmentStatusGroup" resultType="java.util.Map">
        SELECT
            status as name,
            COUNT(1) as value
        FROM sys_uav_equipment
        GROUP BY status
    </select>

    <select id="selectTaskTrendLast7Days" resultType="java.util.Map">
        SELECT
            DATE_FORMAT(start_time, '%m-%d') as dateStr,
            COUNT(1) as taskCount
        FROM sys_uav_task
        WHERE start_time >= DATE_SUB(CURDATE(), INTERVAL 6 DAY)
        GROUP BY DATE_FORMAT(start_time, '%m-%d')
        ORDER BY dateStr ASC
    </select>

</mapper>