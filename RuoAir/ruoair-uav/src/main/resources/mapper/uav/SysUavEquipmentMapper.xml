<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoair.uav.mapper.SysUavEquipmentMapper">
    
    <resultMap type="SysUavEquipment" id="SysUavEquipmentResult">
        <result property="equipmentId"    column="equipment_id"    />
        <result property="equipmentCode"    column="equipment_code"    />
        <result property="equipmentName"    column="equipment_name"    />
        <result property="equipmentModel"    column="equipment_model"    />
        <result property="flightDuration"    column="flight_duration"    />
        <result property="cameraParams"    column="camera_params"    />
        <result property="owner"    column="owner"    />
        <result property="status"    column="status"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectSysUavEquipmentVo">
        select equipment_id, equipment_code, equipment_name, equipment_model, flight_duration, camera_params, owner, status, create_by, create_time, update_by, update_time, remark from sys_uav_equipment
    </sql>

    <select id="selectSysUavEquipmentList" parameterType="SysUavEquipment" resultMap="SysUavEquipmentResult">
        <include refid="selectSysUavEquipmentVo"/>
        <where>  
            <if test="equipmentCode != null  and equipmentCode != ''"> and equipment_code = #{equipmentCode}</if>
            <if test="equipmentName != null  and equipmentName != ''"> and equipment_name like concat('%', #{equipmentName}, '%')</if>
            <if test="equipmentModel != null  and equipmentModel != ''"> and equipment_model = #{equipmentModel}</if>
            <if test="owner != null  and owner != ''"> and owner like concat('%', #{owner}, '%')</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
        </where>
    </select>
    
    <select id="selectSysUavEquipmentByEquipmentId" parameterType="Long" resultMap="SysUavEquipmentResult">
        <include refid="selectSysUavEquipmentVo"/>
        where equipment_id = #{equipmentId}
    </select>

    <insert id="insertSysUavEquipment" parameterType="SysUavEquipment" useGeneratedKeys="true" keyProperty="equipmentId">
        insert into sys_uav_equipment
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="equipmentCode != null and equipmentCode != ''">equipment_code,</if>
            <if test="equipmentName != null and equipmentName != ''">equipment_name,</if>
            <if test="equipmentModel != null">equipment_model,</if>
            <if test="flightDuration != null">flight_duration,</if>
            <if test="cameraParams != null">camera_params,</if>
            <if test="owner != null">owner,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="equipmentCode != null and equipmentCode != ''">#{equipmentCode},</if>
            <if test="equipmentName != null and equipmentName != ''">#{equipmentName},</if>
            <if test="equipmentModel != null">#{equipmentModel},</if>
            <if test="flightDuration != null">#{flightDuration},</if>
            <if test="cameraParams != null">#{cameraParams},</if>
            <if test="owner != null">#{owner},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updateSysUavEquipment" parameterType="SysUavEquipment">
        update sys_uav_equipment
        <trim prefix="SET" suffixOverrides=",">
            <if test="equipmentCode != null and equipmentCode != ''">equipment_code = #{equipmentCode},</if>
            <if test="equipmentName != null and equipmentName != ''">equipment_name = #{equipmentName},</if>
            <if test="equipmentModel != null">equipment_model = #{equipmentModel},</if>
            <if test="flightDuration != null">flight_duration = #{flightDuration},</if>
            <if test="cameraParams != null">camera_params = #{cameraParams},</if>
            <if test="owner != null">owner = #{owner},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where equipment_id = #{equipmentId}
    </update>

    <delete id="deleteSysUavEquipmentByEquipmentId" parameterType="Long">
        delete from sys_uav_equipment where equipment_id = #{equipmentId}
    </delete>

    <delete id="deleteSysUavEquipmentByEquipmentIds" parameterType="String">
        delete from sys_uav_equipment where equipment_id in 
        <foreach item="equipmentId" collection="array" open="(" separator="," close=")">
            #{equipmentId}
        </foreach>
    </delete>
</mapper>
