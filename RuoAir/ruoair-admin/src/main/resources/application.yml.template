# ============================================
# 若飞无人机管理系统 — 配置文件模板
# 使用说明：
#   1. 复制此文件为 application.yml
#   2. 将 {{占位符}} 替换为你的真实配置
#   3. application.yml 已在 .gitignore 中排除，不会提交到仓库
# ============================================

# 开发环境配置
server:
  port: 8081
  servlet:
    context-path: /
  tomcat:
    uri-encoding: UTF-8
    threads:
      max: 800
      min-spare: 30

spring:
  profiles:
    active: druid
  messages:
    basename: i18n/messages
  jackson:
    time-zone: GMT+8
    date-format: yyyy-MM-dd HH:mm:ss
  datasource:
    type: com.alibaba.druid.pool.DruidDataSource
    driver-class-name: com.mysql.cj.jdbc.Driver
    url: jdbc:mysql://localhost:3306/ruoair?useUnicode=true&characterEncoding=utf8&zeroDateTimeBehavior=convertToNull&useSSL=true&serverTimezone=GMT%2B8
    username: {{数据库用户名}}
    password: {{数据库密码}}
    druid:
      initial-size: 5
      min-idle: 10
      max-active: 20
      max-wait: 60000
      stat-view-servlet:
        enabled: true
        url-pattern: /druid/*
        login-username: {{Druid监控用户名}}
        login-password: {{Druid监控密码}}
      filter:
        stat:
          enabled: true
          log-slow-sql: true
          slow-sql-millis: 1000
        wall:
          enabled: true

  # 文件上传
  servlet:
    multipart:
      max-file-size: 50MB
      max-request-size: 50MB

# 若依框架配置
ruoyi:
  name: RuoYi
  version: 3.9.2
  copyrightYear: 2026
  profile: {{上传文件存储路径，如 D:/ruoair/uploadPath}}
  captchaType: math

# Token 配置
token:
  header: Authorization
  secret: {{JWT密钥，随机字符串如 abcdefghijklmnopqrstuvwxyz}}
  expireTime: 30

# AI识别配置（千问VL模型）
# 从 https://dashscope.console.aliyun.com 申请 API Key
ai:
  qwen:
    enabled: {{true 或 false}}
    api-key: {{你的千问API Key}}
    model: qwen-vl-max
    base-url: https://dashscope.aliyuncs.com/compatible-mode/v1
