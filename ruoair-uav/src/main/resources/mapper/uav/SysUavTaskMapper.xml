<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoair.uav.mapper.SysUavTaskMapper">
    
    <resultMap type="SysUavTask" id="SysUavTaskResult">
        <result property="taskId"    column="task_id"    />
        <result property="taskName"    column="task_name"    />
        <result property="taskDescription"    column="task_description"    />
        <result property="equipmentId"    column="equipment_id"    />
        <result property="routeId"    column="route_id"    />
        <result property="taskStatus"    column="task_status"    />
        <result property="startTime"    column="start_time"    />
        <result property="endTime"    column="end_time"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
        <result property="executor"    column="executor"    />
        <result property="progress"    column="progress"    />
        <result property="equipmentName"    column="equipment_name"    />
        <result property="routeName"    column="route_name"    />
        <result property="statusHistory"    column="status_history"    />
    </resultMap>

    <sql id="selectSysUavTaskVo">
        select
            t.task_id, t.task_name, t.task_description, t.equipment_id, t.route_id, t.task_status, t.start_time, t.end_time,
            t.create_by, t.create_time, t.update_by, t.update_time, t.remark, t.executor, t.progress, t.status_history,
            e.equipment_name, r.route_name
        from sys_uav_task t
            left join sys_uav_equipment e on t.equipment_id = e.equipment_id
            left join sys_uav_route r on t.route_id = r.route_id
    </sql>

    <select id="selectSysUavTaskList" parameterType="SysUavTask" resultMap="SysUavTaskResult">
        <include refid="selectSysUavTaskVo"/>
        <where>  
            <if test="taskName != null  and taskName != ''"> and t.task_name like concat('%', #{taskName}, '%')</if>
            <if test="equipmentId != null "> and t.equipment_id = #{equipmentId}</if>
            <if test="routeId != null "> and t.route_id = #{routeId}</if>
            <if test="taskStatus != null  and taskStatus != ''"> and t.task_status = #{taskStatus}</if>
            <if test="executor != null and executor != ''"> and t.executor like concat('%', #{executor}, '%')</if>
            <if test="equipmentName != null and equipmentName != ''"> and e.equipment_name like concat('%', #{equipmentName}, '%')</if>
            <if test="params.beginStartTime != null and params.beginStartTime != '' and params.endStartTime != null and params.endStartTime != ''"> and t.start_time between #{params.beginStartTime} and #{params.endStartTime}</if>
        </where>
        order by t.task_id desc
    </select>
    
    <select id="selectSysUavTaskByTaskId" parameterType="Long" resultMap="SysUavTaskResult">
        <include refid="selectSysUavTaskVo"/>
        where t.task_id = #{taskId}
    </select>

    <insert id="insertSysUavTask" parameterType="SysUavTask" useGeneratedKeys="true" keyProperty="taskId">
        insert into sys_uav_task
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="taskName != null and taskName != ''">task_name,</if>
            <if test="taskDescription != null">task_description,</if>
            <if test="equipmentId != null">equipment_id,</if>
            <if test="routeId != null">route_id,</if>
            <if test="taskStatus != null and taskStatus != ''">task_status,</if>
            <if test="startTime != null">start_time,</if>
            <if test="endTime != null">end_time,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
            <if test="executor != null and executor != ''">executor,</if>
            <if test="progress != null">progress,</if>
            <if test="statusHistory != null">status_history,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="taskName != null and taskName != ''">#{taskName},</if>
            <if test="taskDescription != null">#{taskDescription},</if>
            <if test="equipmentId != null">#{equipmentId},</if>
            <if test="routeId != null">#{routeId},</if>
            <if test="taskStatus != null and taskStatus != ''">#{taskStatus},</if>
            <if test="startTime != null">#{startTime},</if>
            <if test="endTime != null">#{endTime},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
            <if test="executor != null and executor != ''">#{executor},</if>
            <if test="progress != null">#{progress},</if>
            <if test="statusHistory != null">#{statusHistory},</if>
         </trim>
    </insert>

    <update id="updateSysUavTask" parameterType="SysUavTask">
        update sys_uav_task
        <trim prefix="SET" suffixOverrides=",">
            <if test="taskName != null and taskName != ''">task_name = #{taskName},</if>
            <if test="taskDescription != null">task_description = #{taskDescription},</if>
            <if test="equipmentId != null">equipment_id = #{equipmentId},</if>
            <if test="routeId != null">route_id = #{routeId},</if>
            <if test="taskStatus != null and taskStatus != ''">task_status = #{taskStatus},</if>
            <if test="startTime != null">start_time = #{startTime},</if>
            <if test="endTime != null">end_time = #{endTime},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="executor != null and executor != ''">executor = #{executor},</if>
            <if test="progress != null">progress = #{progress},</if>
            <if test="statusHistory != null">status_history = #{statusHistory},</if>
        </trim>
        where task_id = #{taskId}
    </update>

    <delete id="deleteSysUavTaskByTaskId" parameterType="Long">
        delete from sys_uav_task where task_id = #{taskId}
    </delete>

    <delete id="deleteSysUavTaskByTaskIds" parameterType="String">
        delete from sys_uav_task where task_id in 
        <foreach item="taskId" collection="array" open="(" separator="," close=")">
            #{taskId}
        </foreach>
    </delete>
</mapper>
